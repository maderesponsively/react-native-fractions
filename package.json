{
  "name": "react-native-fractions",
  "version": "0.3.0",
  "description": "Native stacked fractions for React Native (inline text layout on iOS and Android)",
  "source": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index.ts",
  "license": "MIT",
  "author": "David Smith <hello@maderesponsively.com> (https://github.com/maderesponsively)",
  "homepage": "https://github.com/maderesponsively/react-native-fractions#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maderesponsively/react-native-fractions.git"
  },
  "bugs": {
    "url": "https://github.com/maderesponsively/react-native-fractions/issues"
  },
  "keywords": [
    "react-native",
    "fraction",
    "fractions",
    "math",
    "text",
    "typography",
    "inline",
    "native",
    "ios",
    "android",
    "typescript"
  ],
  "files": [
    "src",
    "lib",
    "docs",
    "android",
    "ios",
    "react-native-fractions.podspec",
    "README.md",
    "LICENSE",
    "!**/__tests__",
    "!**/*.test.*",
    "!**/.*",
    "!android/build",
    "!android/.gradle",
    "!android/.cxx",
    "!ios/build",
    "!ios/Pods",
    "!ios/DerivedData",
    "!**/node_modules"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf lib",
    "build": "bob build",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run test:ci && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-builder-bob": "^0.40.0",
    "react-test-renderer": "19.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      ["commonjs", { "esm": true }],
      ["module", { "esm": true }],
      "typescript"
    ]
  }
}
